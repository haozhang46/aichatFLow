{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aichatflow.local/schemas/agent-spec.schema.json",
  "title": "AgentSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "version",
    "systemPrompt",
    "availableTools",
    "runtime"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "systemPrompt": {
      "type": "string",
      "minLength": 1
    },
    "availableTools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "maxSteps"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["agent", "react", "workflow", "auto"]
        },
        "engine": {
          "type": "string",
          "enum": ["otie", "deepagent"]
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "allowReplan": {
          "type": "boolean"
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "file", "trace", "custom"]
        },
        "root": {
          "type": "string"
        },
        "windowSize": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "outputSchema": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiresUserContext": {
          "type": "boolean"
        },
        "allowFileAccess": {
          "type": "boolean"
        },
        "allowNetworkAccess": {
          "type": "boolean"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["core", "agent-pack", "custom"]
        },
        "path": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "registered", "published", "disabled", "deprecated"]
    }
  }
}
